# KeirekiPro command allowlist.
# Purpose: allow AGENTS.md quality-gate commands without repeated approval prompts.
# Keep these rules narrow. Do not add deploy, push, merge, rm, or broad shell patterns here.

# --- Frontend quality gates ---
prefix_rule(
    pattern = ["docker", "compose", "exec", "-u", "node", "-w", "/home/node/app", "frontend", "pnpm", "run", ["format", "lint", "coverage"]],
    decision = "allow",
    justification = "KeirekiPro frontend quality-gate commands from AGENTS.md",
    match = [
        "docker compose exec -u node -w /home/node/app frontend pnpm run format",
        "docker compose exec -u node -w /home/node/app frontend pnpm run lint",
        "docker compose exec -u node -w /home/node/app frontend pnpm run coverage",
    ],
)

prefix_rule(
    pattern = ["docker", "compose", "exec", "-u", "node", "-w", "/home/node/app", "frontend", "pnpm", "test"],
    decision = "allow",
    justification = "KeirekiPro frontend test command from AGENTS.md",
    match = [
        "docker compose exec -u node -w /home/node/app frontend pnpm test",
    ],
)

prefix_rule(
    pattern = ["docker", "compose", "exec", "-u", "node", "-w", "/home/node/app", "frontend", "npx", "tsc", "-b"],
    decision = "allow",
    justification = "KeirekiPro frontend typecheck command",
    match = [
        "docker compose exec -u node -w /home/node/app frontend npx tsc -b",
    ],
)

# --- Frontend targeted local checks ---
prefix_rule(
    pattern = ["docker", "compose", "exec", "-u", "node", "-w", "/home/node/app", "frontend", "npx", "prettier", "--write"],
    decision = "allow",
    justification = "Allow targeted Prettier formatting inside frontend container",
)

prefix_rule(
    pattern = ["docker", "compose", "exec", "-u", "node", "-w", "/home/node/app", "frontend", "npx", "eslint"],
    decision = "allow",
    justification = "Allow targeted ESLint checks inside frontend container",
)

prefix_rule(
    pattern = ["docker", "compose", "exec", "-u", "node", "-w", "/home/node/app", "frontend", "npx", "vitest", "run"],
    decision = "allow",
    justification = "Allow targeted Vitest runs inside frontend container",
)

# --- Dev server control for Playwright MCP ---
prefix_rule(
    pattern = [
        "docker", "compose", "exec", "-d",
        "-u", "node",
        "-w", "/home/node/app",
        "frontend",
        "pnpm", "run", "dev",
    ],
    decision = "allow",
    justification = "Allow starting Vite dev server for Playwright MCP UI verification",
    match = [
        "docker compose exec -d -u node -w /home/node/app frontend pnpm run dev",
    ],
)

prefix_rule(
    pattern = [
        "docker", "compose", "exec", "-d",
        "-w", "/home/spring/app",
        "backend",
        "./gradlew", "bootRun",
        "--args=--spring.profiles.active=dev",
    ],
    decision = "allow",
    justification = "Allow starting Spring Boot dev server for Playwright MCP UI verification",
    match = [
        "docker compose exec -d -w /home/spring/app backend ./gradlew bootRun --args=--spring.profiles.active=dev",
    ],
)

prefix_rule(
    pattern = ["docker", "compose", "restart", "frontend"],
    decision = "allow",
    justification = "Allow stopping Vite dev server after Playwright MCP UI verification",
    match = [
        "docker compose restart frontend",
    ],
)

prefix_rule(
    pattern = ["docker", "compose", "restart", "backend"],
    decision = "allow",
    justification = "Allow stopping Spring Boot dev server after Playwright MCP UI verification",
    match = [
        "docker compose restart backend",
    ],
)

# --- Backend quality gates ---
prefix_rule(
    pattern = ["docker", "compose", "exec", "-w", "/home/spring/app", "backend", "./gradlew", ["spotlessApply", "check", "test", "spotlessCheck", "jacocoTestReport"]],
    decision = "allow",
    justification = "KeirekiPro backend Gradle quality-gate commands from AGENTS.md",
    match = [
        "docker compose exec -w /home/spring/app backend ./gradlew spotlessApply",
        "docker compose exec -w /home/spring/app backend ./gradlew check",
        "docker compose exec -w /home/spring/app backend ./gradlew test",
        "docker compose exec -w /home/spring/app backend ./gradlew spotlessCheck",
        "docker compose exec -w /home/spring/app backend ./gradlew jacocoTestReport",
    ],
)

prefix_rule(
    pattern = ["docker", "compose", "exec", "-w", "/home/spring/app", "backend", "./gradlew", "checkstyleMain", "checkstyleTest"],
    decision = "allow",
    justification = "KeirekiPro backend Checkstyle quality-gate command from AGENTS.md",
    match = [
        "docker compose exec -w /home/spring/app backend ./gradlew checkstyleMain checkstyleTest",
    ],
)

prefix_rule(
    pattern = ["docker", "compose", "exec", "-w", "/home/spring/app", "backend", "./gradlew", "spotbugsMain", "spotbugsTest"],
    decision = "allow",
    justification = "KeirekiPro backend SpotBugs quality-gate command from AGENTS.md",
    match = [
        "docker compose exec -w /home/spring/app backend ./gradlew spotbugsMain spotbugsTest",
    ],
)

# --- Terraform quality gates ---
prefix_rule(
    pattern = ["docker", "compose", "exec", "-w", "/workspace", "terraform", "terraform", "fmt", "-check", "-recursive"],
    decision = "allow",
    justification = "KeirekiPro Terraform fmt quality-gate command from AGENTS.md",
    match = [
        "docker compose exec -w /workspace terraform terraform fmt -check -recursive",
    ],
)

prefix_rule(
    pattern = ["docker", "compose", "exec", "-w", "/workspace", "terraform", "terraform", "validate"],
    decision = "allow",
    justification = "KeirekiPro Terraform validate quality-gate command from AGENTS.md",
    match = [
        "docker compose exec -w /workspace terraform terraform validate",
    ],
)

prefix_rule(
    pattern = ["docker", "compose", "exec", "-w", "/workspace", "terraform", "tflint", "--recursive"],
    decision = "allow",
    justification = "KeirekiPro Terraform tflint quality-gate command from AGENTS.md",
    match = [
        "docker compose exec -w /workspace terraform tflint --recursive",
    ],
)

prefix_rule(
    pattern = ["docker", "compose", "exec", "-w", "/workspace", "terraform", "checkov", "-d", "."],
    decision = "allow",
    justification = "KeirekiPro Terraform checkov quality-gate command from AGENTS.md",
    match = [
        "docker compose exec -w /workspace terraform checkov -d .",
    ],
)

# --- Safe final inspection commands ---
prefix_rule(
    pattern = ["git", "status", "--short"],
    decision = "allow",
    justification = "Read-only final diff inspection command from AGENTS.md",
    match = [
        "git status --short",
    ],
)

prefix_rule(
    pattern = ["git", "diff"],
    decision = "allow",
    justification = "Read-only final diff inspection command from AGENTS.md",
    match = [
        "git diff",
        "git diff --stat",
    ],
)

# --- Git branch creation ---
prefix_rule(
    pattern = ["git", "branch", "--show-current"],
    decision = "allow",
    justification = "Read-only current branch inspection command",
    match = [
        "git branch --show-current",
    ],
)

prefix_rule(
    pattern = ["git", "switch", "-c"],
    decision = "allow",
    justification = "Allow creating task branches according to AGENTS.md",
)

# --- Safe Docker inspection commands ---
prefix_rule(
    pattern = ["docker", "ps"],
    decision = "allow",
    justification = "Read-only Docker container inspection command",
    match = [
        "docker ps",
        "docker ps -a",
    ],
)

prefix_rule(
    pattern = ["docker", "compose", "ps"],
    decision = "allow",
    justification = "Read-only Docker Compose service inspection command",
    match = [
        "docker compose ps",
    ],
)
