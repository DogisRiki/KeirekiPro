' usecase.user.notification
'========================================
package com.example.keirekipro.usecase.user.notification {
    class UserDeletedNotification <<record>> {
        + String to
        + String username
        + String applicationName
    }

    class UserRegisteredNotification <<record>> {
        + String to
        + String username
        + String applicationName
    }

    UserDeletedNotification ..|> Notification
    UserRegisteredNotification ..|> Notification
}

'========================================
' usecase.user.dto
'========================================
package com.example.keirekipro.usecase.user.dto {
    class UserInfoUseCaseDto {
        - UUID id
        - String email
        - String username
        - String profileImage
        - List<AuthProviderInfo> authProviders
        - Set<String> roles
    }
}

'========================================
' usecase.user.command
'========================================
package com.example.keirekipro.usecase.user.command {
    class ChangePasswordCommand {
        - UUID userId
        - String nowPassword
        - String newPassword
    }

    class SetEmailAndPasswordCommand {
        - UUID userId
        - String email
        - String password
    }

    class UpdateUserInfoCommand {
        - UUID userId
        - String username
        - ProfileImageCommand profileImage
        - boolean twoFactorAuthEnabled
    }

    class "UpdateUserInfoCommand.ProfileImageCommand" as ProfileImageCommand {
        - byte[] content
        - String contentType
        - String originalFilename
    }

    UpdateUserInfoCommand --> ProfileImageCommand
}

'========================================
' usecase.user
'========================================
package com.example.keirekipro.usecase.user {
    class GetUserInfoUseCase {
        - UserRepository userRepository
        - ObjectStore objectStore
        --
        + UserInfoUseCaseDto execute(UUID userId)
    }

    class UpdateUserInfoUseCase {
        - UserRepository userRepository
        - ObjectStore objectStore
        --
        + void execute(UpdateUserInfoCommand command)
    }

    class ChangePasswordUseCase {
        - UserRepository userRepository
        - PasswordEncoder passwordEncoder
        --
        + void execute(ChangePasswordCommand command)
    }

    class SetEmailAndPasswordUseCase {
        - UserRepository userRepository
        - PasswordEncoder passwordEncoder
        --
        + void execute(SetEmailAndPasswordCommand command)
    }

    class RemoveAuthProviderUseCase {
        - UserRepository userRepository
        --
        + void execute(UUID userId, String providerName)
    }

    class DeleteUserUseCase {
        - UserRepository userRepository
        - DomainEventPublisher eventPublisher
        --
        + void execute(UUID userId)
    }

    GetUserInfoUseCase ..> UserInfoUseCaseDto
    GetUserInfoUseCase --> ObjectStore
    UpdateUserInfoUseCase --> ObjectStore
}

@enduml
