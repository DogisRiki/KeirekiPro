'========================================
' usecase.resume.command
'========================================
package com.example.keirekipro.usecase.resume.command {
    class ExportResumeCommand {
        - ExportFormat format
        - ExportDisposition disposition
        - PdfSettings pdfSettings
        --
        + boolean isPreview()
    }

    enum "ExportResumeCommand.ExportDisposition" as ExportDisposition {
        INLINE
        ATTACHMENT
    }

    class "ExportResumeCommand.PdfSettings" as PdfSettings <<record>> {
        + String fontFamily
        + BigDecimal titleFontSize
        + BigDecimal dateFontSize
        + BigDecimal fullNameFontSize
        + BigDecimal sectionHeadingFontSize
        + String tableHeaderColor
    }

    ExportResumeCommand --> ExportFormat
    ExportResumeCommand --> ExportDisposition
    ExportResumeCommand --> PdfSettings

    class CreateResumeCommand {
        - UUID userId
        - String resumeName
        - UUID resumeId
    }

    class CreateCareerCommand {
        - UUID userId
        - String resumeId
        - String companyName
        - YearMonth startDate
        - YearMonth endDate
        - Boolean active
    }

    class CreateCertificationCommand {
        - UUID userId
        - String resumeId
        - String name
        - YearMonth date
    }

    class UpdateCertificationCommand {
        - UUID userId
        - String resumeId
        - UUID certificationId
        - String name
        - YearMonth date
    }

    class CreatePortfolioCommand {
        - UUID userId
        - String resumeId
        - String name
        - String overview
        - String techStack
        - String link
    }

    class UpdatePortfolioCommand {
        - UUID userId
        - String resumeId
        - UUID portfolioId
        - String name
        - String overview
        - String techStack
        - String link
    }

    class UpdateCareerCommand {
        - UUID userId
        - String resumeId
        - UUID careerId
        - String companyName
        - YearMonth startDate
        - YearMonth endDate
        - Boolean active
    }

    class CreateProjectCommand {
        - UUID userId
        - String resumeId
        - String companyName
        - YearMonth startDate
        - YearMonth endDate
        - Boolean active
        - String name
        - String overview
        ...
    }

    class UpdateProjectCommand {
        - UUID userId
        - String resumeId
        - UUID projectId
        - String companyName
        - YearMonth startDate
        - YearMonth endDate
        - Boolean active
        - String name
        - String overview
        ...
    }

    class RestoreResumeCommand {
        - UUID userId
        - String version
        - ResumeCommand resume
    }

    class UpdateResumeBasicCommand {
        - UUID userId
        - String resumeId
        - String resumeName
        - LocalDate date
        - String lastName
        - String firstName
    }

    class CreateSnsPlatformCommand {
        - UUID userId
        - String resumeId
        - String name
        - String link
    }

    class UpdateSnsPlatformCommand {
        - UUID userId
        - String resumeId
        - UUID snsPlatformId
        - String name
        - String link
    }

    class CreateSelfPromotionCommand {
        - UUID userId
        - String resumeId
        - String title
        - String content
    }

    class UpdateSelfPromotionCommand {
        - UUID userId
        - String resumeId
        - UUID selfPromotionId
        - String title
        - String content
    }

    class "RestoreResumeCommand.ResumeCommand" as RestoreResumeCommandResume {
        - String resumeName
        - LocalDate date
        - String lastName
        - String firstName
        - List<CareerCommand> careers
        - List<ProjectCommand> projects
        ...
    }

    class "RestoreResumeCommand.CareerCommand" as RestoreCareerCommand {
        - String companyName
        - YearMonth startDate
        - YearMonth endDate
        - boolean active
    }

    class "RestoreResumeCommand.ProjectCommand" as RestoreProjectCommand {
        - String companyName
        - YearMonth startDate
        - YearMonth endDate
        - boolean active
        - String name
        - String overview
        ...
    }

    RestoreResumeCommand --> RestoreResumeCommandResume
    RestoreResumeCommandResume --> RestoreCareerCommand
    RestoreResumeCommandResume --> RestoreProjectCommand
}

'========================================
' usecase.resume
'========================================
package com.example.keirekipro.usecase.resume {
    class CreateResumeUseCase {
        - ResumeRepository resumeRepository
        - ResumeNameDuplicationCheckService resumeNameDuplicationCheckService
        - ResumeLimitChecker resumeLimitChecker
        --
        + ResumeInfoUseCaseDto execute(CreateResumeCommand command)
    }

    class CopyCreateResumeUseCase {
        - ResumeRepository resumeRepository
        - ResumeNameDuplicationCheckService resumeNameDuplicationCheckService
        - ResumeLimitChecker resumeLimitChecker
        --
        + ResumeInfoUseCaseDto execute(CreateResumeCommand command)
    }

    class GetResumeListUseCase {
        - ResumeRepository resumeRepository
        --
        + List<ResumeListUseCaseDto> execute(UUID userId)
    }

    class GetResumeInfoUseCase {
        - ResumeRepository resumeRepository
        --
        + ResumeInfoUseCaseDto execute(UUID userId, String resumeId)
    }

    class DeleteResumeUseCase {
        - ResumeRepository resumeRepository
        --
        + void execute(UUID userId, String resumeId)
    }

    class UpdateResumeBasicUseCase {
        - ResumeRepository resumeRepository
        --
        + ResumeInfoUseCaseDto execute(UpdateResumeBasicCommand command)
    }

    class ExportResumeUseCase {
        - ResumeRepository resumeRepository
        - ResumeExportRuleCheckService resumeExportRuleCheckService
        - ResumePdfExporter pdfExporter
        - ResumeMarkdownExporter markdownExporter
        --
        + ExportResumeUseCaseDto execute(UUID userId, String resumeId, ExportResumeCommand command)
    }

    class BackupResumeUseCase {
        - ResumeBackupQuery resumeBackupQuery
        --
        + BackupResumeUseCaseDto execute(UUID userId, String resumeId)
    }

    class RestoreResumeUseCase {
        - ResumeLimitChecker resumeLimitChecker
        - ResumeNameDuplicationCheckService resumeNameDuplicationCheckService
        - ResumeRepository resumeRepository
        --
        + ResumeInfoUseCaseDto execute(RestoreResumeCommand command)
    }

    ' Career CRUD
    class CreateCareerUseCase {
        - ResumeRepository resumeRepository
        - ResumeLimitChecker resumeLimitChecker
        --
        + ResumeInfoUseCaseDto execute(CreateCareerCommand command)
    }

    class UpdateCareerUseCase {
        - ResumeRepository resumeRepository
        --
        + ResumeInfoUseCaseDto execute(UpdateCareerCommand command)
    }

    class DeleteCareerUseCase {
        - ResumeRepository resumeRepository
        --
        + void execute(UUID userId, String resumeId, UUID careerId)
    }

    ' Project CRUD
    class CreateProjectUseCase {
        - ResumeRepository resumeRepository
        - ResumeLimitChecker resumeLimitChecker
        --
        + ResumeInfoUseCaseDto execute(CreateProjectCommand command)
    }

    class UpdateProjectUseCase {
        - ResumeRepository resumeRepository
        --
        + ResumeInfoUseCaseDto execute(UpdateProjectCommand command)
    }

    class DeleteProjectUseCase {
        - ResumeRepository resumeRepository
        --
        + void execute(UUID userId, String resumeId, UUID projectId)
    }

    ' Certification CRUD
    class CreateCertificationUseCase {
        - ResumeRepository resumeRepository
        - ResumeLimitChecker resumeLimitChecker
        --
        + ResumeInfoUseCaseDto execute(CreateCertificationCommand command)
    }

    class UpdateCertificationUseCase {
        - ResumeRepository resumeRepository
        --
        + ResumeInfoUseCaseDto execute(UpdateCertificationCommand command)
    }

    class DeleteCertificationUseCase {
        - ResumeRepository resumeRepository
        --
        + void execute(UUID userId, String resumeId, UUID certificationId)
    }

    ' Portfolio CRUD
    class CreatePortfolioUseCase {
        - ResumeRepository resumeRepository
        - ResumeLimitChecker resumeLimitChecker
        --
        + ResumeInfoUseCaseDto execute(CreatePortfolioCommand command)
    }

    class UpdatePortfolioUseCase {
        - ResumeRepository resumeRepository
        --
        + ResumeInfoUseCaseDto execute(UpdatePortfolioCommand command)
    }

    class DeletePortfolioUseCase {
        - ResumeRepository resumeRepository
        --
        + void execute(UUID userId, String resumeId, UUID portfolioId)
    }

    ' SnsPlatform CRUD
    class CreateSnsPlatformUseCase {
        - ResumeRepository resumeRepository
        - ResumeLimitChecker resumeLimitChecker
        --
        + ResumeInfoUseCaseDto execute(CreateSnsPlatformCommand command)
    }

    class UpdateSnsPlatformUseCase {
        - ResumeRepository resumeRepository
        --
        + ResumeInfoUseCaseDto execute(UpdateSnsPlatformCommand command)
    }

    class DeleteSnsPlatformUseCase {
        - ResumeRepository resumeRepository
        --
        + void execute(UUID userId, String resumeId, UUID snsPlatformId)
    }

    ' SelfPromotion CRUD
    class CreateSelfPromotionUseCase {
        - ResumeRepository resumeRepository
        - ResumeLimitChecker resumeLimitChecker
        --
        + ResumeInfoUseCaseDto execute(CreateSelfPromotionCommand command)
    }

    class UpdateSelfPromotionUseCase {
        - ResumeRepository resumeRepository
        --
        + ResumeInfoUseCaseDto execute(UpdateSelfPromotionCommand command)
    }

    class DeleteSelfPromotionUseCase {
        - ResumeRepository resumeRepository
        --
        + void execute(UUID userId, String resumeId, UUID selfPromotionId)
    }

    class ResumeIdResolver {
        --
        + {static} UUID resolve(String resumeId)
    }

    ' 依存関係
    CreateResumeUseCase --> ResumeLimitChecker
    CopyCreateResumeUseCase --> ResumeLimitChecker
    CreateCareerUseCase --> ResumeLimitChecker
    CreateProjectUseCase --> ResumeLimitChecker
    CreateCertificationUseCase --> ResumeLimitChecker
    CreatePortfolioUseCase --> ResumeLimitChecker
    CreateSnsPlatformUseCase --> ResumeLimitChecker
    CreateSelfPromotionUseCase --> ResumeLimitChecker
    RestoreResumeUseCase --> ResumeLimitChecker
    GetResumeInfoUseCase ..> ResumeIdResolver
    DeleteResumeUseCase ..> ResumeIdResolver
    UpdateResumeBasicUseCase ..> ResumeIdResolver
    ExportResumeUseCase ..> ResumeIdResolver
    BackupResumeUseCase ..> ResumeIdResolver
    CreateCareerUseCase ..> ResumeIdResolver
    UpdateCareerUseCase ..> ResumeIdResolver
    DeleteCareerUseCase ..> ResumeIdResolver
    CreateProjectUseCase ..> ResumeIdResolver
    UpdateProjectUseCase ..> ResumeIdResolver
    DeleteProjectUseCase ..> ResumeIdResolver
    CreateCertificationUseCase ..> ResumeIdResolver
    UpdateCertificationUseCase ..> ResumeIdResolver
    DeleteCertificationUseCase ..> ResumeIdResolver
    CreatePortfolioUseCase ..> ResumeIdResolver
    UpdatePortfolioUseCase ..> ResumeIdResolver
    DeletePortfolioUseCase ..> ResumeIdResolver
    CreateSnsPlatformUseCase ..> ResumeIdResolver
    UpdateSnsPlatformUseCase ..> ResumeIdResolver
    DeleteSnsPlatformUseCase ..> ResumeIdResolver
    CreateSelfPromotionUseCase ..> ResumeIdResolver
    UpdateSelfPromotionUseCase ..> ResumeIdResolver
    DeleteSelfPromotionUseCase ..> ResumeIdResolver

    ExportResumeUseCase --> ResumePdfExporter
    ExportResumeUseCase --> ResumeMarkdownExporter
    ExportResumeUseCase ..> ExportFormat
    ExportResumeUseCase ..> ExportResumeCommand
    BackupResumeUseCase --> ResumeBackupQuery
}

