package com.example.keirekipro.usecase.query.resume {
    interface ResumeBackupQuery {
        + Optional<ResumeBackupQueryDto> findByIdForBackup(UUID resumeId, UUID userId)
    }

    interface ResumeCountQuery {
        + int countByUserId(UUID userId)
    }
}

package com.example.keirekipro.usecase.query.resume.dto {
    class ResumeBackupQueryDto {
        - String resumeName
        - LocalDate date
        - String lastName
        - String firstName
        - List<CareerDto> careers
        - List<ProjectDto> projects
        - List<CertificationDto> certifications
        - List<PortfolioDto> portfolios
        - List<SnsPlatformDto> snsPlatforms
        - List<SelfPromotionDto> selfPromotions
    }
}

CertificationListQuery ..> CertificationListQueryDto
SnsPlatformListQuery ..> SnsPlatformListQueryDto
TechStackListQuery ..> TechStackListQueryDto
ResumeBackupQuery ..> ResumeBackupQueryDto

'========================================
' usecase.resume.export
'========================================
package com.example.keirekipro.usecase.resume.export {
    interface ResumePdfExporter {
        + ExportedFile export(Resume resume, ResumePdfExportSettings settings)
    }

    interface ResumeMarkdownExporter {
        + ExportedFile export(Resume resume)
    }

    class ExportedFile {
        - String fileName
        - String contentType
        - byte[] data
    }

    enum ExportFormat {
        PDF
        MARKDOWN
    }

    class ResumePdfExportSettings <<record>> {
        + String fontFamily
        + BigDecimal titleFontSize
        + BigDecimal dateFontSize
        + BigDecimal fullNameFontSize
        + BigDecimal sectionHeadingFontSize
        + String tableHeaderColor
        --
        + {static} ResumePdfExportSettings defaults()
        + {static} ResumePdfExportSettings normalize(...)
    }

    ResumePdfExporter ..> ExportedFile
    ResumePdfExporter ..> ResumePdfExportSettings
    ResumeMarkdownExporter ..> ExportedFile
}

'========================================
' usecase.resume.policy
'========================================
package com.example.keirekipro.usecase.resume.policy {
    class ResumeLimits {
        + {static} int RESUMES_CREATION_LIMIT
        + {static} int CAREERS_CREATION_LIMIT
        + {static} int PROJECTS_CREATION_LIMIT
        + {static} int CERTIFICATIONS_CREATION_LIMIT
        + {static} int SNS_PLATFORMS_CREATION_LIMIT
        + {static} int PORTFOLIOS_CREATION_LIMIT
        + {static} int SELF_PROMOTIONS_CREATION_LIMIT
    }

    class ResumeBackupVersion {
        + {static} String SUPPORTED_VERSION
    }

    class ResumeLimitChecker {
        - ResumeCountQuery resumeCountQuery
        --
        + void check(UUID userId)
    }

    ResumeLimitChecker --> ResumeCountQuery
}

